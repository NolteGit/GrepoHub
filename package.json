{
  "name": "grepo-hub",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "clean": "rimraf dist .angular coverage",
    "clean:all": "rimraf dist .angular coverage node_modules package-lock.json",
    "reinstall": "npm run clean:all && npm install",
    "verify": "npm run clean && npm install && npm run build",
    "zip:clean": "npm run clean && rimraf grepo-hub-clean.zip && bestzip grepo-hub-clean.zip docs/ public/ src/ .vscode/ .editorconfig .gitignore .prettierrc angular.json package.json package-lock.json README.md todo.md tsconfig.json tsconfig.app.json tsconfig.spec.json",
    "dev:clean": "npm run clean && npm run build && npm run start"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "bestzip": "^2.2.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
