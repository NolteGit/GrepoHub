{
  "name": "grepo-hub",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",

    "test": "ng test",
    "test:once": "ng test --watch=false",

    "typecheck": "tsc --noEmit",
    "deadcode": "knip",

    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\" \"*.{json,md}\"",

    "clean": "rimraf dist .angular/cache coverage",
    "fresh": "rimraf node_modules package-lock.json dist .angular coverage && npm install",

    "verify": "npm run typecheck && npm run test:once && npm run build",
    "check": "npm run format:check && npm run typecheck && npm run test:once && npm run build && npm run deadcode"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "bestzip": "^2.2.3",
    "jsdom": "^28.0.0",
    "knip": "^6.12.2",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
