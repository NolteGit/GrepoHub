{
  "name": "grepo-hub",
  "version": "0.0.0",
  "scripts": {
    "start": "nx serve grepo-hub",
    "build": "nx build grepo-hub",
    "test": "nx test grepo-hub",
    "test:once": "nx test grepo-hub --watch=false",
    "typecheck": "tsc --noEmit",
    "deadcode": "knip",
    "assets:audit": "node scripts/audit-assets.mjs",
    "i18n:audit": "node scripts/audit-i18n.mjs",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\" \"*.{json,md}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\" \"*.{json,md}\" \"docs/**/*.md\"",
    "clean": "rimraf dist .angular/cache coverage",
    "fresh": "rimraf node_modules dist .angular coverage && npm ci",
    "verify": "npm run format:check && npm run assets:audit && npm run i18n:audit && npm run typecheck && npm run test:once && npm run build && npm run deadcode",
    "verify:fix": "npm run format && npm run verify"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@angular/router": "^21.2.14",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.12",
    "@angular-devkit/schematics": "^21.2.12",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@nx/angular": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@schematics/angular": "^21.2.12",
    "@tailwindcss/postcss": "^4.3.0",
    "jsdom": "^28.0.0",
    "knip": "^6.12.2",
    "nx": "22.7.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
